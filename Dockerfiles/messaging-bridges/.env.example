# Messaging Bridges Configuration
# Copy to .env and fill in values, or run ./setup.sh
#
# Usage: cp .env.example .env

# =====================================================
# General
# =====================================================
# Timezone for all containers
TIMEZONE=America/Costa_Rica

# =====================================================
# WhatsApp Bridge (Baileys)
# =====================================================
# Port for WhatsApp HTTP API (default: 3100)
WHATSAPP_PORT=3100
# Pull latest code from GitHub on container restart (default: false)
WHATSAPP_AUTO_UPDATE=false
# No API keys needed - WhatsApp uses QR code pairing
# Watch logs on first run: docker logs -f whatsapp-bridge

# =====================================================
# Telegram Bridge (Telethon)
# =====================================================
# Get API credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Phone number with country code (e.g., +50612345678)
TELEGRAM_PHONE=
# Port for Telegram HTTP API (default: 8081)
TELEGRAM_PORT=8081
# Pull latest code from GitHub on container restart (default: false)
TELEGRAM_AUTO_UPDATE=false

# =====================================================
# Slack Bridge (Bolt.js)
# =====================================================
# Create app at https://api.slack.com/apps
# Bot Token (xoxb-...) - Bot User OAuth Token
SLACK_BOT_TOKEN=
# App Token (xapp-...) - Enable Socket Mode first
SLACK_APP_TOKEN=
# Signing Secret - from app Basic Information page
SLACK_SIGNING_SECRET=
# Port for Slack HTTP API (default: 3102)
SLACK_PORT=3102
# Pull latest code from GitHub on container restart (default: false)
SLACK_AUTO_UPDATE=false
